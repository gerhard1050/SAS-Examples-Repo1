-27639dd779d9","portName":"outTable","index":0},"targetPort":{"node":"fde00a40-3437-11f1-87db-27639dd779d9","portName":"inTables","index":0}},{"sourcePort":{"node":"fde00a40-3437-11f1-87db-27639dd779d9","portName":"outTables","index":0},"targetPort":{"node":"46140260-343a-11f1-87db-27639dd779d9","portName":"inTable","index":0}},{"sourcePort":{"node":"fde00a40-3437-11f1-87db-27639dd779d9","portName":"outTables","index":1},"targetPort":{"node":"4a45ec40-343a-11f1-87db-27639dd779d9","portName":"inTable","index":0}}],"createdBy":null,"creationTimeStamp":"2026-04-10T08:59:30.170Z","description":"","eTag":null,"extendedProperties":{},"modifiedBy":null,"modifiedTimeStamp":"2026-04-10T08:59:30.170Z","name":"","nodes":{"46140260-343a-11f1-87db-27639dd779d9":{"description":"","id":"46140260-343a-11f1-87db-27639dd779d9","name":"BIGORG_SCORED_R","nodeType":"outputTable","note":null,"priority":0,"properties":{"UI_PROP_LOCATION":"523 987.338623046875","UI_PROP_INPUT_PORT|inTable|0":"|inTable|","UI_PROP_OUTPUT_PORT|outTable|0":"|outTable|","usePersistedTableStructure":"false"},"version":1,"tableReference":{"referenceType":"parameter","parameterId":"46140260-343a-11f1-87db-27639dd779d9"},"outputTableArguments":{"advancedOptions":[],"arguments":{}}},"f0311470-3437-11f1-87db-27639dd779d9":{"description":"","id":"f0311470-3437-11f1-87db-27639dd779d9","name":"BIGORG_20PCTSAMPLE","nodeType":"table","note":null,"priority":1,"properties":{"UI_PROP_LOCATION":"65 1041.494873046875","UI_PROP_INPUT_PORT|inTable|0":"|inTable|","UI_PROP_OUTPUT_PORT|outTable|0":"|outTable|","usePersistedTableStructure":"false"},"version":1,"tableReference":{"referenceType":"parameter","parameterId":"f0311470-3437-11f1-87db-27639dd779d9"}},"fde00a40-3437-11f1-87db-27639dd779d9":{"description":"","id":"fde00a40-3437-11f1-87db-27639dd779d9","name":"R LogReg Full","nodeType":"step","note":null,"priority":2,"properties":{"UI_PROP_LOCATION":"253 1042.494873046875","UI_PROP_INPUT_PORT|inTables|0":"|Input table 1|Input tables","UI_PROP_OUTPUT_PORT|outTables|0":"|Output table 1|Output tables","UI_PROP_OUTPUT_PORT|outTables|1":"|Output table 2|Output tables","UI_PROP_IS_INPUT_EXPANDED":"false","UI_PROP_IS_OUTPUT_EXPANDED":"false"},"version":1,"stepReference":{"type":"uri","path":"/dataFlows/steps/a7190700-f59c-4a94-afe2-214ce639fcde"},"arguments":{"codeOptions":{"code":"proc r;\r\nsubmit;\r\n\r\n\r\n\r\n\r\n# =========================================================\r\n# 1. Read SAS dataset into R\r\n# =========================================================\r\n\r\ndf <- sd2df(\"WORK.BIGORG_20PCTSAMPLE\")\r\n\r\n#df <- read.sasdata(table = \"BIGORG_20PCTSAMPLE\", libref = \"WORK\")\r\n\r\n# =========================================================\r\n# 2. Prepare variables\r\n# =========================================================\r\n\r\n# Convert categorical variables to factors\r\ndf$DemGender <- as.factor(df$DemGender)\r\ndf$PromClass <- as.factor(df$PromClass)\r\n\r\n# Ensure target is numeric (0/1)\r\ndf$TargetBuy <- as.numeric(df$TargetBuy)\r\n\r\n# Drop missing values\r\ndf <- df[complete.cases(df[, c(\"TargetBuy\",\r\n                              \"DemAge\", \"DemAffl\", \"PromTime\", \"PromSpend\",\r\n                              \"DemGender\", \"PromClass\")]), ]\r\n\r\n# =========================================================\r\n# 3. Logistic regression (like PROC LOGISTIC)\r\n# =========================================================\r\n\r\nmodel <- glm(\r\n  TargetBuy ~ DemAge + DemAffl + PromTime + PromSpend +\r\n              DemGender + PromClass,\r\n  data = df,\r\n  family = binomial(link = \"logit\")\r\n)\r\n\r\n# =========================================================\r\n# 4. Predicted probabilities → SAS\r\n# =========================================================\r\n\r\ndf$P_TargetBuy1 <- predict(model, type = \"response\")\r\n\r\n# Write scored dataset back to SAS\r\n# write.sasdata(df, table = \"BIGORG_SCORED_R\", libref = \"WORK\")\r\n\r\ndf2sd(df, \"BIGORG_SCORED_R\",libref='WORK')\r\n\r\n# =========================================================\r\n# 5. Parameter estimates → SAS\r\n# =========================================================\r\n\r\n# Extract coefficients\r\ncoef_table <- as.data.frame(summary(model)$coefficients)\r\n\r\n# Clean up table\r\ncoef_table$Variable <- rownames(coef_table)\r\nrownames(coef_table) <- NULL\r\n\r\n# Reorder columns\r\ncoef_table <- coef_table[, c(\"Variable\",\r\n                            \"Estimate\",\r\n                            \"Std. Error\",\r\n                            \"z value\",\r\n                            \"Pr(>|z|)\")]\r\n\r\n# Write to SAS\r\n# write.sasdata(coef_table, table = \"BIGORG_PARAMS_R\", libref = \"WORK\")\r\n\r\ndf2sd(coef_table, \"BIGORG_PARAMS_R\", libref='WORK')\r\n\r\nendsubmit;\r\nrun;","contentType":"embedded","variables":[{"name":"_input1","value":{"referenceType":"inputPort","portName":"inTables","portIndex":0}},{"name":"_output1","value":{"referenceType":"outputPort","portName":"outTables","portIndex":0,"arguments":{}}},{"name":"_output2","value":{"referenceType":"outputPort","portName":"outTables","portIndex":1,"arguments":{}}}]}},"portMappings":[{"mappingType":"tableStructure","portName":"outTables","portIndex":0,"tableStructure":{"columnDefinitions":[{"name":"_PartInd_","version":2,"index":0,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"TargetBuy","version":2,"index":1,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"id","version":2,"index":2,"byteLength":32767,"charLength":32767,"type":"Char","Aggregate":"","rawLength":32767,"formattedLength":0},{"name":"DemAffl","version":2,"index":3,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"DemAge","version":2,"index":4,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"DemCluster","version":2,"index":5,"byteLength":32767,"charLength":32767,"type":"Char","Aggregate":"","rawLength":32767,"formattedLength":0},{"name":"DemGender","version":2,"index":6,"byteLength":32767,"charLength":32767,"type":"Char","Aggregate":"","rawLength":32767,"formattedLength":0},{"name":"DemTVReg","version":2,"index":7,"byteLength":32767,"charLength":32767,"type":"Char","Aggregate":"","rawLength":32767,"formattedLength":0},{"name":"DemClusterGroup","version":2,"index":8,"byteLength":32767,"charLength":32767,"type":"Char","Aggregate":"","rawLength":32767,"formattedLength":0},{"name":"DemReg","version":2,"index":9,"byteLength":32767,"charLength":32767,"type":"Char","Aggregate":"","rawLength":32767,"formattedLength":0},{"name":"PromClass","version":2,"index":10,"byteLength":32767,"charLength":32767,"type":"Char","Aggregate":"","rawLength":32767,"formattedLength":0},{"name":"PromSpend","version":2,"index":11,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"PromTime","version":2,"index":12,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"TargetAmt","version":2,"index":13,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"P_TargetBuy1","version":2,"index":14,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0}]}},{"mappingType":"tableStructure","portName":"outTables","portIndex":1,"tableStructure":{"columnDefinitions":[{"name":"Variable","version":2,"index":0,"byteLength":32767,"charLength":32767,"type":"Char","Aggregate":"","rawLength":32767,"formattedLength":0},{"name":"Estimate","version":2,"index":1,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"Std__Error","version":2,"index":2,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formatted