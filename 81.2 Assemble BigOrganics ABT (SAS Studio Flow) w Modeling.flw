arguments":{}}}]}},"portMappings":[{"mappingType":"tableStructure","portName":"outTables","portIndex":0,"tableStructure":{"columnDefinitions":[]}},{"mappingType":"tableStructure","portName":"outTables","portIndex":1,"tableStructure":{"columnDefinitions":[{"name":"_PRED_","version":2,"index":0,"byteLength":8,"charLength":-1,"label":"Predicted Value","type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"id","version":2,"index":1,"byteLength":12,"charLength":12,"label":"Customer Loyalty ID","type":"Char","Aggregate":"","rawLength":12,"formattedLength":0},{"name":"TargetBuy","version":2,"index":2,"byteLength":8,"charLength":-1,"label":"Organics Purchase Indicator","type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"_PartInd_","version":2,"index":3,"byteLength":8,"charLength":-1,"label":"Partition Indicator","type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0}]}}]},"22fc7ad0-343c-11f1-87db-27639dd779d9":{"description":"","id":"22fc7ad0-343c-11f1-87db-27639dd779d9","name":"02 Reduce Variables","nodeType":"step","note":null,"priority":3,"properties":{"UI_PROP_LOCATION":"586.22056875 1221.5026855468745","UI_PROP_INPUT_PORT|inTables|0":"|Input table 1|Input tables","UI_PROP_OUTPUT_PORT|outTables|0":"|Output table 1|Output tables","UI_PROP_IS_INPUT_EXPANDED":"false","UI_PROP_IS_OUTPUT_EXPANDED":"false"},"version":1,"stepReference":{"type":"uri","path":"/dataFlows/steps/a7190700-f59c-4a94-afe2-214ce639fcde"},"arguments":{"codeOptions":{"code":"/*--------------------------------------------------------------*\r\n| 2) Variable reduction (supervised) |\r\n| Adjust predictor lists below to match your BIGORGANICS |\r\n| column names (these are the common ones used in training). |\r\n*--------------------------------------------------------------*/\r\n\r\n\r\nproc binning data=casuser.bigorganics_smp method=tree;\r\n\r\n target TargetBuy      /level=  nominal;\r\n input DemCluster /level = nominal;\r\n\r\n output outlevelbinmap=casuser.outlevel;\r\n code file=\"&path./BigOrg_Binning_Eventname.sas\";\r\nrun;\r\n\r\n\r\n\r\ndata casuser.bigorganics_smp;\r\n set casuser.bigorganics_smp;\r\n\r\n %include \"&path./BigOrg_Binning_Eventname.sas\";\r\n\r\n rename BIN_NOM_DemCluster = DemCluster_Binned;\r\nrun;\r\n\r\n\r\n\r\n\r\nproc varreduce data=casuser.bigorganics_smp matrix=COV tech=DSC;\r\nods output SelectionSummary=work.Summary;\r\n\r\n/* Categorical predictors */\r\nclass DemGender DemReg DemTVReg DemClusterGroup PromClass DemCluster TargetBuy DemCluster_Binned;\r\n\r\n/* Supervised reduction: TargetBuy is the target */\r\nreduce supervised TargetBuy =\r\nDemAge PromTime PromSpend PromClass\r\nDemGender DemAffl DemReg DemTVReg DemClusterGroup\r\nDemCluster\r\n/ maxiter=15 BIC;\r\n\r\ndisplay 'SelectionSummary' 'SelectedEffects';\r\nrun;\r\n\r\nproc sgplot data=work.Summary;\r\nseries x=Iteration y=BIC;\r\nrun;","contentType":"embedded","variables":[{"name":"_input1","value":{"referenceType":"inputPort","portName":"inTables","portIndex":0}},{"name":"_output1","value":{"referenceType":"outputPort","portName":"outTables","portIndex":0,"arguments":{}}}]}},"portMappings":[{"mappingType":"tableStructure","portName":"outTables","portIndex":0,"tableStructure":{"columnDefinitions":[]}}]},"00642040-343c-11f1-87db-27639dd779d9":{"description":"","id":"00642040-343c-11f1-87db-27639dd779d9","name":"BIGORGANICS_SMP","nodeType":"outputTable","note":null,"priority":4,"properties":{"UI_PROP_LOCATION":"396.12056875 1223.8266980468745","UI_PROP_INPUT_PORT|inTable|0":"|inTable|","UI_PROP_OUTPUT_PORT|outTable|0":"|outTable|","usePersistedTableStructure":"false"},"version":1,"tableReference":{"referenceType":"parameter","parameterId":"00642040-343c-11f1-87db-27639dd779d9"},"outputTableArguments":{"advancedOptions":[],"arguments":{"CAS":{"promote":false,"replaceWithPromote":false,"persist":false,"replaceWithPersist":false}}}},"134db2d0-343b-11f1-87db-27639dd779d9":{"description":"","id":"134db2d0-343b-11f1-87db-27639dd779d9","name":"01 Sample and Partition","nodeType":"step","note":null,"priority":5,"properties":{"UI_PROP_LOCATION":"197.02056875 1228.4026855468744","UI_PROP_INPUT_PORT|inTables|0":"|Input table 1|Input tables","UI_PROP_OUTPUT_PORT|outTables|0":"|Output table 1|Output tables","UI_PROP_IS_INPUT_EXPANDED":"false","UI_PROP_IS_OUTPUT_EXPANDED":"false"},"version":1,"stepReference":{"type":"uri","path":"/dataFlows/steps/a7190700-f59c-4a94-afe2-214ce639fcde"},"arguments":{"codeOptions":{"code":"* %let path = /export/home/users/autges/sas_code; *** CACTUS;\r\n%let path =  /srv/nfs/kubedata/compute-landingzone/Gerhard/sas_code;\r\n\r\n\r\n/*--------------------------------------------------------------*\r\n| 1) Create partitions |\r\n| - First: optional event sampling (kept from your template) |\r\n| - Second: Train/Valid/Test split |\r\n*--------------------------------------------------------------*/\r\n\r\n/* If you do NOT want event sampling, skip this block and use\r\ncasuser.BIGORGANICS directly in the second PARTITION. */\r\n/***\r\nproc partition data=casuser.BIGORGANICS\r\nsamppctevt=100 eventprop=0.05 event=\"1\" seed=1;\r\noutput out=casuser.bigorganics_smp copyvars=(_all_);\r\nby TargetBuy;\r\nrun;\r\n***/\r\ndata casuser.bigorganics_smp;\r\nset casuser.BIGORGANICS;\r\nrun;\r\n\r\n\r\nproc freqtab data=casuser.bigorganics_smp;\r\ntables TargetBuy;\r\nrun;\r\n\r\nproc partition data=casuser.bigorganics_smp\r\nsamppct=50 samppct2=25 partind;\r\noutput out=casuser.bigorganics_smp copyvars=(_all_);\r\nrun;\r\n/* 1=TRN 0=VLD 2=TST */\r\n\r\nproc freqtab data=casuser.bigorganics_smp;\r\ntables _PartInd_;\r\nrun;","contentType":"embedded","variables":[{"name":"_input1","value":{"referenceType":"inputPort","portName":"inTables","portIndex":0}},{"name":"_output1","value":{"referenceType":"outputPort","portName":"outTables","portIndex":0,"arguments":{}}}]}},"portMappings":[{"mappingType":"tableStructure","portName":"outTables","portIndex":0,"tableStructure":{"columnDefinitions":[{"name":"id","version":2,"index":0,"byteLength":12,"charLength":12,"label":"Customer Loyalty ID","type":"Char","Aggregate":"","rawLength":12,"formattedLength":0},{"name":"DemAffl","version":2,"index":1,"byteLength":8,"charLength":-1,"label":"Affluence Grade","type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"DemAge","version":2,"index":2,"byteLength":8,"charLength":-1,"label":"Age","type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"DemCluster","version":2,"index":3,"byteLength":2,"charLength":2,"label":"Neighborhood Cluster-55 Level","type":"Char","Aggregate":"","rawLength":2,"formattedLength":0},{"name":"DemClusterGroup","version":2,"index":4,"byteLength":1,"charLength":1,"label":"Neighborhood Cluster-7 Level","type":"Char","Aggregate":"","rawLength":1,"formattedLength":0},{"name":"DemGender","version":2,"index":5,"byteLength":1,"charLength":1,"label":"Gender","type":"Char","Aggregate":"","rawLength":1,"formattedLength":0},{"name":"DemReg","version":2,"index":6,"byteLength":10,"charLength":10,"label":"Geographic Region","type":"Char","Aggregate":"","rawLength":10,"formattedLength":0},{"name":"DemTVReg","version":2,"index":7,"byteLength":12,"charLength":12,"label":"Television Region","type":"Char","Aggregate":"","rawLength":12,"formattedLength":0},{"name":"PromClass","version":2,"index":8,"byteLength":8,"charLength":8,"label":"Loyalty Status","type":"Char","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"PromSpend","version":2,"index":9,"byteLength":8,"charLength":-1,"label":"Total Spend","type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"PromTime","version":2,"index":10,"byteLength":8,"charLength":-1,"label":"Loyalty Card Tenure","type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"TargetBuy","version":2,"index":11,"byteLength":8,"charLength":-1,"label":"Organics Purchase Indicator","type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"TargetAmt","version":2,"index":12,"byteLength":8,"charLength":-1,"label":"Organics Purchase Count","type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"_PartInd_","version":2,"index":13,"byteLength":8,"charLength":-1,"label":"Partition Indicator","type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0},{"name":"DemCluster_Binned","version":2,"index":14,"byteLength":8,"charLength":-1,"type":"Numeric","Aggregate":"","rawLength":8,"formattedLength":0}]}}]},"edcac600-343b-11f1-87db-27639dd779d9":{"description":"","id":"edcac600-343b-11f1-87db-27639dd779d9","name":"BIGORGANICS","nodeType":"table","note":null,"priority":6,"properties":{"UI_PROP_LOCATION":"65 1236.0657605468741","UI_PROP_INPUT_PORT|inTable|0":"|inTable|","UI_PROP_OUTPUT_PORT|outTable|0":"|outTable|"},"version":1,"tableReference":{"referenceType":"parameter","parameterId":"edcac600-343b-11f1-87db-27639dd779d9"}},"c413f380-343c-11f1-87db-27639dd779d9":{"description":"","id":"c413f380-343c-11f1-87db-27639dd779d9","name":"05 Assessment","nodeType":"step","note":null,"priority":7,"properties":{"UI_PROP_LOCATION":"1078.25 1262.4526855468746","UI_PROP_INPUT_PORT|inTables|0":"|Input table 1|Input tables","UI_PROP_INPUT_PORT|inTables|1":"|Input table 2|Input tables","UI_PROP_OUTPUT_PORT|outTables|0":"|Output table 1|Output tables","UI_PROP_IS_INPUT_EXPANDED":"false","UI_PROP_IS_OUTPUT_EXPANDED":"false"},"version":1,"stepReference":{"type":"uri","path":"/dataFlows/steps/a7190700-f59c-4a94-afe2-214ce639fcde"},"arguments":{"codeOptions":{"code":"/*--------------------------------------------------------------*\r\n| 5) Assessment (Lift + ROC) |\r\n*--------------------------------------------------------------*/\r\n\r\nproc format;\r\nvalue part_ind 0='Valid' 1='Train' 2='Test';\r\nrun;\r\n\r\n/* Assess logistic regression */\r\nproc assess data=casuser.bigorganics_logreg_score ncuts=10 nbins=10;\r\nvar _pred_;\r\ntarget TargetBuy / event=\"1\" level=nominal;\r\nby _PartInd_;\r\nods output liftinfo=work.liftinfo_LR rocinfo=work.rocinfo_LR;\r\nrun;\r\n\r\nproc sgplot data=work.liftinfo_LR;\r\ntitle 'Lift Chart (Logistic Regression)';\r\nformat _PartInd_ part_ind.;\r\nseries x=Depth y=Lift / group=_PartInd_;\r\nrun;\r\ntitle;\r\n\r\ndata work.rocinfo_LR;\r\nset work.rocinfo_LR;\r\nSpec_minus1 = 1 - Specificity;\r\nrun;\r\n\r\nproc sgplot data=work.rocinfo_LR;\r\ntitle 'ROC Chart (Logistic Regression)';\r\nformat _PartInd_ part_ind.;\r\nseries x=Spec_minus1 y=Sensitivity / group=_PartInd_;\r\nrun;\r\ntitle;\r\n\r\n/* Assess gradient boosting */\r\nproc assess data=casuser.bigorganics_gb_score ncuts=10 nbins=10;\r\n/* For a nominal binary target, GB commonly outputs P_TargetBuy1 */\r\nvar P_TargetBuy1;\r\ntarget TargetBuy / event=\"1\" level=nominal;\r\nby _PartInd_;\r\nods output liftinfo=work.liftinfo_GB rocinfo=work.rocinfo_GB;\r\nrun;\r\n\r\nproc sgplot data=work.liftinfo_GB;\r\ntitle 'Lift Chart (Gradient Boosting)';\r\nformat _PartInd_ part_ind.;\r\nseries x=Depth y=Lift / group=_PartInd_;\r\nrun;\r\ntitle;\r\n\r\ndata work.rocinfo_GB;\r\nset work.rocinfo_GB;\r\nSpec_minus1 = 1 - Specificity;\r\nrun;\r\n\r\nproc sgplot data=work.rocinfo_GB;\r\ntitle 'ROC Chart (Gradient Boosting)';\r\nformat _PartInd_ part_ind.;\r\nseries x=Spec_minus1 y=Sensitivity / group=_PartInd_;\r\nrun;\r\ntitle;\r\n","contentType":"embedded","variables":[{"name":"_input1","value":{"referenceType":"inputPort","portName":"inTables","portIndex":0}},{"name":"_output1","value":{"referenceType":"outputPort","portName":"outTables","portIndex":0,"arguments":{}}},{"name":"_input2","value":{"referenceType":"inputPort","portName":"inTables","portIndex":1}}]}},"portMappings":[{"mappingType":"tableStructure","portName":"outTables","portIndex":0,"tableStructure":{"columnDefinitions":[]}}]},"a5898010-343c-11f1-87db-27639dd779d9":{"description":"","id":"a5898010-343c-11f1-87db-27639dd779d9","name":"04 GradBoost","nodeType":"step","note":null,"priority":8,"properties":