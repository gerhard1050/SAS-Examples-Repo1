"_uuid":"cf7fa196-f6c4-4dd4-b9cc-6034fa4db66a"},{"inColumn":{"referenceType":"column","port":"inTables","portIndex":0,"columnName":"PromTime"},"isModified":false,"modifiedColumn":null,"isCalculated":false,"calculatedColumn":null,"expressionText":null,"_uuid":"8fd6d4d3-11c9-4b41-9fe3-3ec2e6d821d1"},{"inColumn":{"referenceType":"column","port":"inTables","portIndex":0,"columnName":"TargetAmt"},"isModified":false,"modifiedColumn":null,"isCalculated":false,"calculatedColumn":null,"expressionText":null,"_uuid":"5f0fe2ff-2a33-4b40-99f1-a88d8e691e4b"}],"queryJoins":null,"joinFormattedFilter":"","whereQuickFilters":[],"havingQuickFilters":[],"orderByColumns":[],"groupByColumns":[],"explicitSqlSource":false,"calculatedColumns":[],"inTables":[{"referenceType":"inputPort","portName":"inTables","portIndex":0,"arguments":{"alias":"t1"}}],"outTable":{"referenceType":"outputPort","portName":"outTable","portIndex":0,"arguments":{}}},"portMappings":[]},"d70eba90-342f-11f1-87db-27639dd779d9":{"description":"","id":"d70eba90-342f-11f1-87db-27639dd779d9","name":"BigOrg_20PctSample","nodeType":"outputTable","note":null,"priority":4,"properties":{"UI_PROP_LOCATION":"525 738.338623046875","UI_PROP_INPUT_PORT|inTable|0":"|inTable|","UI_PROP_OUTPUT_PORT|outTable|0":"|outTable|","usePersistedTableStructure":"false"},"version":1,"tableReference":{"referenceType":"parameter","parameterId":"d70eba90-342f-11f1-87db-27639dd779d9"},"outputTableArguments":{"advancedOptions":[],"arguments":{}}},"65170130-343a-11f1-87db-27639dd779d9":{"description":"","id":"65170130-343a-11f1-87db-27639dd779d9","name":"BIGORG_SCORED_PY","nodeType":"outputTable","note":null,"priority":5,"properties":{"UI_PROP_LOCATION":"945 782.182373046875","UI_PROP_INPUT_PORT|inTable|0":"|inTable|","UI_PROP_OUTPUT_PORT|outTable|0":"|outTable|","usePersistedTableStructure":"false"},"version":1,"tableReference":{"referenceType":"parameter","parameterId":"65170130-343a-11f1-87db-27639dd779d9"},"outputTableArguments":{"advancedOptions":[],"arguments":{}}},"c3e115f0-3437-11f1-87db-27639dd779d9":{"description":"","id":"c3e115f0-3437-11f1-87db-27639dd779d9","name":"Python Logreg Full","nodeType":"step","note":null,"priority":6,"properties":{"UI_PROP_LOCATION":"752 825.088623046875","UI_PROP_INPUT_PORT|inTables|0":"|Input table 1|Input tables","UI_PROP_OUTPUT_PORT|outTables|0":"|Output table 1|Output tables","UI_PROP_OUTPUT_PORT|outTables|1":"|Output table 2|Output tables","UI_PROP_IS_INPUT_EXPANDED":"false","UI_PROP_IS_OUTPUT_EXPANDED":"false"},"version":1,"stepReference":{"type":"uri","path":"/dataFlows/steps/ab59f8c4-af9a-4608-a5d5-a8365357bb99"},"arguments":{"codeOptions":{"code":"\r\nimport pandas as pd\r\nfrom sklearn.linear_model import LogisticRegression\r\nfrom sklearn.preprocessing import OneHotEncoder\r\nfrom sklearn.compose import ColumnTransformer\r\nfrom sklearn.pipeline import Pipeline\r\n\r\n# Load SAS dataset into pandas\r\ndf = SAS.sd2df('BIGORG_20PCTSAMPLE', libref='WORK')\r\n\r\n# Define variables\r\ntarget = 'TargetBuy'\r\ninterval_vars = ['DemAge', 'DemAffl', 'PromTime', 'PromSpend']\r\nclass_vars = ['DemGender', 'PromClass']\r\n\r\n# Drop missing values (important!)\r\ndf = df.dropna(subset=[target] + interval_vars + class_vars)\r\n\r\n# Split X and y\r\nX = df[interval_vars + class_vars]\r\ny = df[target]\r\n\r\n# Preprocessing:\r\n# - Pass through interval variables\r\n# - One-hot encode categorical variables\r\npreprocessor = ColumnTransformer(\r\n    transformers=[\r\n        ('num', 'passthrough', interval_vars),\r\n        ('cat', OneHotEncoder(drop='first'), class_vars)\r\n    ]\r\n)\r\n\r\n# Create pipeline with logistic regression\r\nmodel = Pipeline(steps=[\r\n    ('prep', preprocessor),\r\n    ('logit', LogisticRegression(max_iter=1000))\r\n])\r\n\r\n# Fit model\r\nmodel.fit(X, y)\r\n\r\n# Print coefficients\r\nfeature_names = (\r\n    interval_vars +\r\n    list(model.named_steps['prep']\r\n         .named_transformers_['cat']\r\n         .get_feature_names_out(class_vars))\r\n)\r\n\r\ncoefficients = model.named_steps['logit'].coef_[0]\r\n\r\nfor name, coef in zip(feature_names, coefficients):\r\n    print(f\"{name}: {coef}\")\r\n\r\n# Intercept\r\nprint(\"Intercept:\", model.named_steps['logit'].intercept_[0])\r\n\r\n\r\n# =========================================================\r\n# ✅ 1. Predicted probabilities → SAS dataset\r\n# =========================================================\r\n\r\n# Probability of class \"1\"\r\ndf['P_TargetBuy1'] = model.predict_proba(X)[:, 1]\r\n\r\n# Write back to SAS\r\nSAS.df2sd(df, 'BIGORG_SCORED_PY', libref='WORK')\r\n\r\n# =========================================================\r\n# ✅ 2. Parameter estimates table → SAS dataset\r\n# =========================================================\r\n\r\n# Get feature names\r\ncat_features = list(\r\n    model.named_steps['prep']\r\n    .named_transformers_['cat']\r\n    .get_feature_names_out(class_vars)\r\n)\r\n\r\nfeature_names = interval_vars + cat_features\r\n\r\n# Coefficients\r\ncoefficients = model.named_steps['logit'].coef_[0]\r\n\r\n# Create parameter table\r\nparam_df = pd.DataFrame({\r\n    'Variable': feature_names,\r\n    'Estimate': coefficients\r\n})\r\n\r\n# Add intercept\r\nintercept_df = pd.DataFrame({\r\n    'Variable': ['Intercept'],\r\n    'Estimate': [model.named_steps['logit'].intercept_[0]]\r\n})\r\n\r\nparam_df = pd.concat([intercept_df, param_df], ignore_index=True)\r\n\r\n# Write parameter table to SAS\r\nSAS.df2sd(param_df, 'BIGORG_PARAMS_PY', libref='WORK')\r\n\r\n","contentType":"embedded","variables":[{"name":"_input1","value":{"referenceType":"inputPort","portName":"inTables","portIndex":0}},{"name":"_output1","value":{"referenceType":"outputPort","portName":"outTables","portIndex":0,"arguments":{}}},{"name":"_output2","value":{"referenceType":"outputPort","portName":"outTables","portIndex":1,"arguments":{}}}]}},"portMappings":[{"mappingType":"tableStructure","portName":"outTables","portIndex":0,"tableStructure":{"columnDefinitions":[]}},{"mappingType":"tableStructure","portName":"outTables","portIndex":1,"tableStructure":{"columnDefinitions":[]}}]},"68c11d70-343a-11f1-87db-27639dd779d9":{"description":"","id":"68c11d70-343a-11f1-87db-27639dd779d9","name":"BIGORG_PARAMS_PY","nodeType":"outputTable","note":null,"priority":7,"properties":{"UI_PROP_LOCATION":"1119 851.182373046875","UI_PROP_INPUT_PORT|inTable|0":"|inTable|","UI_PROP_OUTPUT_PORT|outTable|0":"|outTable|","usePersistedTableStructure":"false"},"version":1,"tableReference":{"referenceType":"parameter","parameterId":"68c11d70-343a-11f1-87db-27639dd779d9"},"outputTableArguments":{"advancedOptions":[],"arguments":{}}}},"parameters":{"6cfd4180-342f-11f1-87db-27639dd779d9":{"id":"6cfd4180-342f-11f1-87db-27639dd779d9","name":"BIGORGANICS_FLOW","version":2,"parameterUsage":"INPUT","parameterType":"tableStructure","defaultValue":{"table":{"name":"BIGORGANICS_FLOW","type":"dataTable","version":3,"creationTimeStamp":"2026-04-09T16:14:18.82Z","modifiedTimeStamp":"2026-04-09T16:14:18.82Z","providerId":"Compute","dataSourceId":"Compute~fs~ff826f0d-e7e0-4c77-baf2-79b6e4a8c0f6~fs~WORK","attributes":{"id":"BIGORGANICS_FLOW","libref":"WORK","engine":"V9","compressionRoutine":"NO","bookmarkLength":12,"logicalRecordCount":111115,"columnCount":13,"rowCount":111115,"physicalRecordCount":111115,"recordLength":120,"encoding":"utf-8  Unicode (UTF-8)","isCas":false,"isReadOnly":false,"eTag":"\"qorfz1s4\"","dataTableType":"table"}},"source":{"id":"WORK","name":"WORK","version":2,"parentId":"ff826f0d-e7e0-4c77-baf2-79b6e4a8c0f6","providerId":"Compute","hasTables":true,"hasEngines":false,"createdBy":"","modifiedBy":"","attributes":{"physicalName":"/opt/sas/viya/config/var/tmp/compsrv/default/f4b5fc6e-bc90-4563-a22b-f10b1045f1f2/SAS_work2CA000000164_sas-compute-server-ec88f360-d9a9-410f-965a-84dfa4e76da8-308202","concatenationCount":0,"engineName":"V9","fileFormat":"7","flags":34848,"libref":"WORK","isHadoop":false}}},"columns":[{"name":"id",