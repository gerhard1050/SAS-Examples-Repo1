s]\r\ny = df[target]\r\n\r\n# Preprocessing:\r\n# - Pass through interval variables\r\n# - One-hot encode categorical variables\r\npreprocessor = ColumnTransformer(\r\n    transformers=[\r\n        ('num', 'passthrough', interval_vars),\r\n        ('cat', OneHotEncoder(drop='first'), class_vars)\r\n    ]\r\n)\r\n\r\n# Create pipeline with logistic regression\r\nmodel = Pipeline(steps=[\r\n    ('prep', preprocessor),\r\n    ('logit', LogisticRegression(max_iter=1000))\r\n])\r\n\r\n# Fit model\r\nmodel.fit(X, y)\r\n\r\n# Print coefficients\r\nfeature_names = (\r\n    interval_vars +\r\n    list(model.named_steps['prep']\r\n         .named_transformers_['cat']\r\n         .get_feature_names_out(class_vars))\r\n)\r\n\r\ncoefficients = model.named_steps['logit'].coef_[0]\r\n\r\nfor name, coef in zip(feature_names, coefficients):\r\n    print(f\"{name}: {coef}\")\r\n\r\n# Intercept\r\nprint(\"Intercept:\", model.named_steps['logit'].intercept_[0])\r\n\r\n\r\n# =========================================================\r\n# ✅ 1. Predicted probabilities → SAS dataset\r\n# =========================================================\r\n\r\n# Probability of class \"1\"\r\ndf['P_TargetBuy1'] = model.predict_proba(X)[:, 1]\r\n\r\n# Write back to SAS\r\nSAS.df2sd(df, 'BIGORG_SCORED_PY', libref='WORK')\r\n\r\n# =========================================================\r\n# ✅ 2. Parameter estimates table → SAS dataset\r\n# =========================================================\r\n\r\n# Get feature names\r\ncat_features = list(\r\n    model.named_steps['prep']\r\n    .named_transformers_['cat']\r\n    .get_feature_names_out(class_vars)\r\n)\r\n\r\nfeature_names = interval_vars + cat_features\r\n\r\n# Coefficients\r\ncoefficients = model.named_steps['logit'].coef_[0]\r\n\r\n# Create parameter table\r\nparam_df = pd.DataFrame({\r\n    'Variable': feature_names,\r\n    'Estimate': coefficients\r\n})\r\n\r\n# Add intercept\r\nintercept_df = pd.DataFrame({\r\n    'Variable': ['Intercept'],\r\n    'Estimate': [model.named_steps['logit'].intercept_[0]]\r\n})\r\n\r\nparam_df = pd.concat([intercept_df, param_df], ignore_index=True)\r\n\r\n# Write parameter table to SAS\r\nSAS.df2sd(param_df, 'BIGORG_PARAMS_PY', libref='WORK')\r\n\r\n","contentType":"embedded","variables":[{"name":"_input1","value":{"referenceType":"inputPort","portName":"inTables","portIndex":0}},{"name":"_output1","value":{"referenceType":"outputPort","portName":"outTables","portIndex":0,"arguments":{}}},{"name":"_output2","value":{"referenceType":"outputPort","portName":"outTables","portIndex":1,"arguments":{}}}]}},"portMappings":[{"mappingType":"tableStructure","portName":"outTables","portIndex":0,"tableStructure":{"columnDefinitions":[]}},{"mappingType":"tableStructure","portName":"outTables","portIndex":1,"tableStructure":{"columnDefinitions":[]}}]},"68c11d70-343a-11f1-87db-27639dd779d9":{"description":"","id":"68c11d70-343a-11f1-87db-27639dd779d9","name":"BIGORG_PARAMS_PY","nodeType":"outputTable","note":null,"priority":7,"properties":{"UI_PROP_LOCATION":"1119 851.182373046875","UI_PROP_INPUT_PORT|inTable|0":"|inTable|","UI_PROP_OUTPUT_PORT|outTable|0":"|outTable|","usePersistedTableStructure":"false"},"version":1,"tableReference":{"referenceType":"parameter","parameterId":"68c11d70-343a-11f1-87db-27639dd779d9"},"outputTableArguments":{"advancedOptions":[],"arguments":{}}}},"parameters":{"6cfd4180-342f-11f1-87db-27639dd779d9":{"id":"6cfd4180-342f-11f1-87db-27639dd779d9","name":"BIGORGANICS_FLOW","version":2,"parameterUsage":"INPUT","parameterType":"tableStructure","defaultValue":{"table":{"name":"BIGORGANICS_FLOW","type":"dataTable","version":3,"creationTimeStamp":"2026-04-09T16:14:18.82Z","modifiedTimeStamp":"2026-04-09T16:14:18.82Z","providerId":"Compute","dataSourceId":"Compute~fs~ff826f0d-e7e0-4c77-baf2-79b6e4a8c0f6~fs~WORK","attributes":{"id":"BIGORGANICS_FLOW","libref":"WORK","engine":"V9","compressionRoutine":"NO","bookmarkLength":12,"logicalRecordCount":111115,"columnCoun